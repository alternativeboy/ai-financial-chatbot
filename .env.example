NODE_ENV=development
PORT=3000

# --- PostgreSQL (application connection) ---
DATABASE_HOST=localhost
# Host port for the Postgres container. Change it if 5432 is already taken on
# your machine — compose publishes ${DATABASE_PORT}:5432, so this value is both
# the published port and the one the backend dials.
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=financial_db
DATABASE_POOL_SIZE=10
# Leave false for the local Docker container. Set true for any managed Postgres
# (Neon, Supabase, Render) — they refuse plaintext connections.
DATABASE_SSL=false

# --- Layer 3 guardrail: SELECT-only role used to run LLM-generated SQL ---
LLM_READER_USER=llm_reader
LLM_READER_PASSWORD=change_me_llm_reader

# --- Claude API (backend only — never expose to the frontend) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- CORS allowlist (explicit origins only, never *) ---
CORS_ORIGIN=http://localhost:5173

# --- frontend/.env (created in Phase 5) ---
# VITE_API_URL=/api
